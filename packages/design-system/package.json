{
  "name": "@repo/design-system",
  "version": "1.0.0",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./theme.css": "./src/theme.css",
    "./styles.css": "./dist/styles.css",
    "./tiptap-color-config.json": "./dist/tiptap-color-config.json",
    "./tiptap-theme.css": "./dist/tiptap-theme.css",
    "./styles-strapi.json": "./dist/styles-strapi.json",
    "./custom-styles.css": "./src/custom-styles.css",
    "./ck-color-config.json": "./dist/ckeditor-color-config.json",
    "./ck-fontSize-config.json": "./dist/ckeditor-fontSize-config.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tailwindcss -i ./src/styles.css -o ./dist/styles.css && node ./src/build-ck-config.js && node ./src/build-tiptap-config.js",
    "dev": "tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "lint": "eslint -c ../../eslint.config.mjs './**/*.{js,ts,jsx,tsx,cjs,mjs}'",
    "lint:fix": "pnpm lint --fix"
  },
  "dependencies": {
    "@tailwindcss/cli": "4.2.4",
    "@tailwindcss/postcss": "4.2.4",
    "class-variance-authority": "0.7.1",
    "postcss": "8.5.14",
    "tailwindcss": "4.2.4"
  },
  "devDependencies": {
    "postcss-modules-values": "4.0.0"
  },
  "engines": {
    "node": "^24.0.0"
  }
}
