{
  "name": "@repo/strapi",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "types": "./types",
  "scripts": {
    "build": "strapi build",
    "config:dump": "strapi configuration:dump -f dump.json",
    "config:restore": "strapi configuration:restore -f dump.json",
    "dev": "pnpm run run:db && pnpm run develop",
    "develop": "strapi develop",
    "develop:watch": "strapi develop --watch-admin",
    "export:all": "strapi export --file strapi-export --no-encrypt",
    "export:content": "strapi export --only content --no-encrypt --file strapi-export",
    "generate": "strapi generate",
    "generate:types": "strapi ts:generate-types",
    "import": "strapi import -f strapi-export.tar.gz",
    "lint": "eslint -c ../../eslint.config.mjs './**/*.{js,ts,jsx,tsx,cjs,mjs}'",
    "lint:fix": "pnpm lint --fix",
    "run:db": "docker compose up -d db",
    "start": "strapi start",
    "strapi": "strapi",
    "test": "vitest run",
    "test:watch": "vitest",
    "transfer": "strapi transfer",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@_sh/strapi-plugin-ckeditor": "7.1.1",
    "@notum-cz/strapi-plugin-tiptap-editor": "1.2.3",
    "@repo/design-system": "workspace:*",
    "@repo/shared-data": "workspace:*",
    "@strapi/database": "5.44.0",
    "@strapi/design-system": "2.2.0",
    "@strapi/plugin-sentry": "5.44.0",
    "@strapi/plugin-users-permissions": "5.44.0",
    "@strapi/provider-email-mailgun": "5.44.0",
    "@strapi/provider-email-nodemailer": "5.44.0",
    "@strapi/provider-upload-aws-s3": "5.44.0",
    "@strapi/strapi": "5.44.0",
    "@strapi/utils": "5.44.0",
    "ckeditor5": "47.6.1",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.18.1",
    "nodemailer": "8.0.7",
    "pg": "8.20.0",
    "qs": "6.15.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "strapi-plugin-config-sync": "3.2.0",
    "styled-components": "6.0.0",
    "vitest": "4.1.5"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "strapi": {
    "uuid": "@repo/strapi"
  }
}
