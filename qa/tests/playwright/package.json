  "main": "index.js",
  "scripts": {
    "axe-test": "playwright test --project=axe",
    "lhci-perfo-check": "tsx perfo/lhci.ts",
    "lint": "eslint -c ../../../eslint.config.mjs './**/*.{js,ts,jsx,tsx,cjs,mjs}'",
    "lint:fix": "pnpm lint --fix",
    "playwright-e2e-tests": "playwright test e2e",
    "playwright-interactive-mode": "playwright test e2e --ui",
    "playwright-seo-tests": "playwright test --project=seo",
    "playwright-visual-tests": "playwright test --project=visual-chromium --project=visual-firefox --project=visual-webkit",
    "playwright-visual-update-tests": "playwright test --project=visual-chromium --project=visual-firefox --project=visual-webkit --update-snapshots",
    "playwright-visual-tests-docker": "bash visual/compare-snapshots-docker.sh visual-chromium visual-firefox visual-webkit",
    "playwright-visual-update-snapshots-docker": "bash visual/update-snapshots-docker.sh visual-chromium visual-firefox visual-webkit"
  },
  "dependencies": {
    "@axe-core/playwright": "4.11.3",
    "axe-core": "4.11.4",
    "get-sitemap-links": "1.1.0"
  },
  "devDependencies": {
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.59.1",
    "@types/node": "24.12.2",
    "dotenv": "17.4.2",
    "eslint-plugin-playwright": "2.10.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "^24.0.0"
  }
}
